{
  "StartupEntry": {
    "next": [
      "LaunchGame"
    ],
    "timeout": 10000,
    "on_error": [
      "StartupFailed"
    ]
  },
  "LaunchGame": {
    "recognition": "DirectHit",
    "action": "StartApp",
    "package": "com.leiting.zjcs",
    "max_hit": 1,
    "post_delay": 3000
  },
  "StartupFailed": {
    "recognition": "DirectHit",
    "action": "StopTask"
  }
}
