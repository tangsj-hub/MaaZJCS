{
  "StartupEntry": {
    "next": [
      "LaunchGame"
    ],
    "timeout": 600000,
    "on_error": [
      "StartupFailed"
    ]
  },
  "LaunchGame": {
    "recognition": "DirectHit",
    "action": "StartApp",
    "package": "com.leiting.zjcs",
    "max_hit": 1,
    "post_delay": 8000,
    "next": [
      "WaitAfterLaunch"
    ],
    "timeout": 120000,
    "on_error": [
      "WaitAfterLaunch"
    ]
  },
  "WaitAfterLaunch": {
    "recognition": "DirectHit",
    "action": "DoNothing",
    "post_delay": 14000,
    "next": [
      "DetectAnnouncementByOcr",
      "DetectAnnouncementByCheckboxTmpl",
      "SkipNoAnnouncementAlreadyAtEnter"
    ],
    "timeout": 90000,
    "on_error": [
      "TapEnterAnywhere"
    ]
  },
  "SkipNoAnnouncementAlreadyAtEnter": {
    "recognition": "OCR",
    "expected": [
      "进入游戏",
      "开始游戏",
      "点击屏幕",
      "点击继续",
      "轻触屏幕",
      "触摸屏幕",
      "点击空白处",
      "任意位置继续"
    ],
    "action": "DoNothing",
    "post_delay": 3500,
    "next": [
      "TapEnterAnywhere"
    ],
    "timeout": 120000
  },
  "DetectAnnouncementByOcr": {
    "recognition": "OCR",
    "expected": [
      "公告",
      "今日不再提示",
      "今日不再",
      "活动",
      "更新公告",
      "活动公告"
    ],
    "action": "DoNothing",
    "post_delay": 600,
    "next": [
      "EnsureNoReminder"
    ],
    "timeout": 120000
  },
  "DetectAnnouncementByCheckboxTmpl": {
    "recognition": "TemplateMatch",
    "template": "startup/no_reminder_today.jpg",
    "threshold": 0.65,
    "action": "DoNothing",
    "post_delay": 400,
    "next": [
      "EnsureNoReminder"
    ],
    "timeout": 120000
  },
  "EnsureNoReminder": {
    "recognition": "DirectHit",
    "action": "DoNothing",
    "post_delay": 300,
    "next": [
      "NoRemindAlreadyCheckedTmpl",
      "NoRemindClickToCheckOcr",
      "NoRemindClickLabelCenterOcr"
    ],
    "timeout": 20000,
    "on_error": [
      "CloseAnnouncementBackLeft"
    ]
  },
  "CloseAnnouncementBackLeft": {
    "recognition": "DirectHit",
    "action": "Click",
    "target": [
      32,
      -120,
      140,
      120
    ],
    "post_delay": 400,
    "next": [
      "CloseAnnouncementOutside"
    ],
    "timeout": 120000,
    "on_error": [
      "CloseAnnouncementOutside"
    ]
  },
  "NoRemindAlreadyCheckedTmpl": {
    "recognition": "TemplateMatch",
    "template": "startup/no_reminder_today.jpg",
    "threshold": 0.72,
    "action": "DoNothing",
    "post_delay": 200,
    "next": [
      "CloseAnnouncementBackLeft"
    ],
    "timeout": 120000
  },
  "NoRemindClickToCheckOcr": {
    "recognition": "OCR",
    "expected": [
      "今日不再提示",
