{
    "interface_version": 2,
    "languages": {
        "zh_cn": "interface_zh.json"
    },
    "name": "MaaZJCS",
    "label": "$project_name",
    "title": "$project_title",
    "version": "0.1.0",
    "description": "$project_description",
    "controller": [
        {
            "name": "Android",
            "label": "$controller_android",
            "description": "$controller_android_desc",
            "type": "Adb",
            "display_short_side": 720
        }
    ],
    "resource": [
        {
            "name": "Official",
            "label": "$resource_official",
            "description": "$resource_official_desc",
            "path": [
                "assets/resource"
            ],
            "controller": [
                "Android"
            ]
        }
    ],
    "task": [
        {
            "name": "StartupAndHome",
            "label": "$task_startup_home",
            "entry": "StartupEntry",
            "default_check": true,
            "description": "$task_startup_home_desc"
        },
        {
            "name": "DailyHandcart",
            "label": "$task_daily_handcart",
            "entry": "DailyHandcartEntry",
            "description": "$task_daily_handcart_desc"
        },
        {
            "name": "DailyHandcartFromCart",
            "label": "$task_daily_handcart_from_cart",
            "entry": "DailyHandcartAtCartEntry",
            "description": "$task_daily_handcart_from_cart_desc"
        },
        {
            "name": "DailyBed",
            "label": "$task_daily_bed",
            "entry": "DailyBedEntry",
            "description": "$task_daily_bed_desc"
        },
        {
            "name": "DailyShop",
            "label": "$task_daily_shop",
            "entry": "DailyShopEntry",
            "description": "$task_daily_shop_desc"
        },
        {
            "name": "DailyTasks",
            "label": "$task_daily_tasks",
            "entry": "DailyTasksEntry",
            "description": "$task_daily_tasks_desc"
        },
        {
            "name": "DailySignIn",
            "label": "$task_daily_sign_in",
            "entry": "DailySignInEntry",
            "description": "$task_daily_sign_in_desc"
        },
        {
            "name": "GrowthTrial",
            "label": "$task_growth_trial",
            "entry": "GrowthTrialEntry",
            "description": "$task_growth_trial_desc"
        },
        {
            "name": "DepartureSignIn",
            "label": "$task_departure_sign_in",
            "entry": "DepartureSignInEntry",
            "description": "$task_departure_sign_in_desc"
        },
        {
            "name": "MainQuest",
            "label": "$task_main_quest",
            "entry": "MainQuestEntry",
            "description": "$task_main_quest_desc"
        },
        {
            "name": "Dungeon",
            "label": "$task_dungeon",
            "entry": "DungeonEntry",
            "description": "$task_dungeon_desc",
            "option": [
                "dungeon_type",
                "dungeon_difficulty"
            ]
        },
        {
            "name": "DungeonBattlePrep",
            "label": "$task_dungeon_battle_prep",
            "entry": "DungeonBattlePrepEntry",
            "description": "$task_dungeon_battle_prep_desc",
            "option": [
                "dungeon_type",
                "dungeon_difficulty",
                "battle_mode",
                "click_ready",
                "claim_reward",
                "like_team",
                "check_hp",
                "hp_threshold"
            ]
        },
        {
            "name": "ExitGame",
            "label": "$task_exit_game",
            "entry": "ExitGameEntry",
            "description": "$task_exit_game_desc"
        }
    ],
    "option": {
        "dungeon_type": {
            "type": "select",
            "label": "$opt_dungeon_type",
            "description": "$opt_dungeon_type_desc",
            "default_case": "sea_palace",
            "cases": [
                {
                    "name": "world_tree",
                    "label": "$opt_dungeon_type_world_tree",
                    "available_difficulties": [
                        "normal",
                        "hard"
                    ],
                    "pipeline_override": {
                        "DungeonTapDungeonName": {
                            "expected": [
                                "世界之树",
                                "世界树"
                            ]
                        },
                        "DungeonSelectDifficulty": {
                            "expected": [
                                "普通"
                            ]
                        },
                        "DungeonBattlePopupNormalOcr": {
                            "expected": [
                                "普通"
                            ]
                        },
                        "DungeonBattlePopupHardOcr": {
                            "expected": [
                                "困难"
                            ]
                        }
                    }
                },
                {
                    "name": "mecha_mountain",
                    "label": "$opt_dungeon_type_mecha_mountain",
                    "available_difficulties": [
                        "normal",
                        "hard"
                    ],
                    "pipeline_override": {
                        "DungeonTapDungeonName": {
                            "expected": [
                                "机神山",
                                "机神"
                            ]
                        },
                        "DungeonSelectDifficulty": {
                            "expected": [
                                "普通"
                            ]
                        },
                        "DungeonBattlePopupNormalOcr": {
                            "expected": [
                                "普通"
                            ]
                        },
                        "DungeonBattlePopupHardOcr": {
                            "expected": [
                                "困难"
                            ]
                        }
                    }
                },
                {
                    "name": "sea_palace",
                    "label": "$opt_dungeon_type_sea_palace",
                    "available_difficulties": [
                        "normal",
                        "hard"
                    ],
                    "pipeline_override": {
                        "DungeonTapDungeonName": {
                            "expected": [
                                "海之宫遗迹",
                                "海之宫"
                            ]
                        },
                        "DungeonSelectDifficulty": {
                            "expected": [
                                "普通"
                            ]
                        },
                        "DungeonBattlePopupNormalOcr": {
                            "expected": [
                                "普通"
                            ]
                        },
                        "DungeonBattlePopupHardOcr": {
                            "expected": [
                                "困难"
                            ]
                        }
                    }
                },
                {
                    "name": "water_source",
                    "label": "$opt_dungeon_type_water_source",
                    "available_difficulties": [
                        "normal",
                        "hard",
                        "nightmare"
                    ],
                    "pipeline_override": {
                        "DungeonTapDungeonName": {
                            "expected": [
                                "源水大社",
                                "源水"
                            ]
                        },
                        "DungeonSelectDifficulty": {
                            "expected": [
                                "普通"
                            ]
                        },
                        "DungeonBattlePopupNormalOcr": {
                            "expected": [
                                "普通"
                            ]
                        },
                        "DungeonBattlePopupHardOcr": {
                            "expected": [
                                "困难"
                            ]
                        },
                        "DungeonBattlePopupNightmareOcr": {
                            "expected": [
                                "噩梦"
                            ]
                        }
                    }
                },
                {
                    "name": "yellow_spring_pavilion",
                    "label": "$opt_dungeon_type_yellow_spring_pavilion",
                    "available_difficulties": [
                        "normal",
                        "hard",
                        "nightmare",
                        "purgatory"
                    ],
                    "pipeline_override": {
                        "DungeonTapDungeonName": {
                            "expected": [
                                "黄泉阁",
                                "黄泉"
                            ]
                        },
                        "DungeonSelectDifficulty": {
                            "expected": [
                                "普通"
                            ]
                        },
                        "DungeonBattlePopupNormalOcr": {
                            "expected": [
                                "普通"
                            ]
                        },
                        "DungeonBattlePopupHardOcr": {
                            "expected": [
                                "困难"
                            ]
                        },
                        "DungeonBattlePopupNightmareOcr": {
                            "expected": [
                                "噩梦"
                            ]
                        },
                        "DungeonBattlePopupPurgatoryOcr": {
                            "expected": [
                                "炼狱"
                            ]
                        }
                    }
                }
            ]
        },
        "dungeon_difficulty": {
            "type": "select",
            "label": "$opt_dungeon_difficulty",
            "description": "$opt_dungeon_difficulty_desc",
            "default_case": "normal",
            "cases": [
                {
                    "name": "normal",
                    "label": "$opt_dungeon_difficulty_normal",
                    "pipeline_override": {
                        "DungeonBattlePopupRoute": {
                            "next": [
                                "DungeonBattlePopupNormalOcr"
                            ]
                        }
                    }
                },
                {
                    "name": "hard",
                    "label": "$opt_dungeon_difficulty_hard",
                    "pipeline_override": {
                        "DungeonBattlePopupRoute": {
                            "next": [
                                "DungeonBattlePopupHardOcr"
                            ]
                        }
                    }
                },
                {
                    "name": "nightmare",
                    "label": "$opt_dungeon_difficulty_nightmare",
                    "pipeline_override": {
                        "DungeonBattlePopupRoute": {
                            "next": [
                                "DungeonBattlePopupNightmareOcr"
                            ]
                        }
                    }
                },
                {
                    "name": "purgatory",
                    "label": "$opt_dungeon_difficulty_purgatory",
                    "pipeline_override": {
                        "DungeonBattlePopupRoute": {
                            "next": [
                                "DungeonBattlePopupPurgatoryOcr"
                            ]
                        }
                    }
                }
            ]
        },
        "battle_mode": {
            "type": "select",
            "label": "$opt_battle_mode",
            "description": "$opt_battle_mode_desc",
            "default_case": "match",
            "cases": [
                {
                    "name": "match",
                    "label": "$opt_battle_mode_match",
                    "pipeline_override": {
                        "DungeonBattleHpGate": {
                            "next": [
                                "DungeonTapScreenArea"
                            ]
                        },
                        "DungeonBattlePopupNormalOcr": {
                            "next": [
                                "DungeonBattlePopupMatchOcr"
                            ]
                        },
                        "DungeonBattlePopupHardOcr": {
                            "next": [
                                "DungeonBattlePopupMatchOcr"
                            ]
                        },
                        "DungeonBattlePopupNightmareOcr": {
                            "next": [
                                "DungeonBattlePopupMatchOcr"
                            ]
                        }
                    }
                },
                {
                    "name": "leader",
                    "label": "$opt_battle_mode_leader",
                    "pipeline_override": {
                        "DungeonBattleHpGate": {
                            "next": [
                                "DungeonLeaderMode"
                            ]
                        },
                        "DungeonBattlePopupNormalOcr": {
                            "next": [
                                "DungeonUiStartBattleOcr"
                            ]
                        },
                        "DungeonBattlePopupHardOcr": {
                            "next": [
                                "DungeonUiStartBattleOcr"
                            ]
                        },
                        "DungeonBattlePopupNightmareOcr": {
                            "next": [
                                "DungeonUiStartBattleOcr"
                            ]
                        }
                    }
                },
                {
                    "name": "member",
                    "label": "$opt_battle_mode_member",
                    "pipeline_override": {
                        "DungeonBattleHpGate": {
                            "next": [
                                "DungeonMemberMode"
                            ]
                        },
                        "DungeonBattlePopupNormalOcr": {
                            "next": [
                                "DungeonUiStartBattleOcr"
                            ]
                        },
                        "DungeonBattlePopupHardOcr": {
                            "next": [
                                "DungeonUiStartBattleOcr"
                            ]
                        },
                        "DungeonBattlePopupNightmareOcr": {
                            "next": [
                                "DungeonUiStartBattleOcr"
                            ]
                        }
                    }
                }
            ]
        },
        "like_team": {
            "type": "select",
            "label": "$opt_like_team",
            "description": "$opt_like_team_desc",
            "default_case": "skip",
            "cases": [
                {
                    "name": "like",
                    "label": "$opt_like_team_like",
                    "pipeline_override": {
                        "DungeonBattleLikeTeam": {
                            "action": "Click"
                        }
                    }
                },
                {
                    "name": "skip",
                    "label": "$opt_like_team_skip",
                    "pipeline_override": {
                        "DungeonBattleLikeTeam": {
                            "recognition": "DirectHit",
                            "action": "DoNothing",
                            "next": [
                                "DungeonBattleClaimRewardOcr"
                            ],
                            "on_error": [
                                "DungeonBattleClaimRewardOcr"
                            ]
                        }
                    }
                }
            ]
        },
        "click_ready": {
            "type": "select",
            "label": "$opt_click_ready",
            "description": "$opt_click_ready_desc",
            "default_case": "no",
            "cases": [
                {
                    "name": "no",
                    "label": "$opt_click_ready_no",
                    "pipeline_override": {
                        "DungeonBattleMatchLoop": {
                            "next": [
                                "DungeonBattleLoadingOcr",
                                "DungeonBattleTapAcceptOcr",
                                "DungeonBattleSettleDetect",
                                "DungeonBattleMatchLoop"
                            ]
                        },
                        "DungeonBattleTapAcceptOcr": {
                            "next": [
                                "DungeonBattleLoadingOcr",
                                "DungeonBattleSettleDetect",
                                "DungeonBattleMatchLoop"
                            ]
                        }
                    }
                },
                {
                    "name": "yes",
                    "label": "$opt_click_ready_yes",
                    "pipeline_override": {
                        "DungeonBattleMatchLoop": {
                            "next": [
                                "DungeonBattleLoadingOcr",
                                "DungeonBattleTapAcceptOcr",
                                "DungeonBattleCancelReadyOcr",
                                "DungeonBattleUiReadyOcr",
                                "DungeonBattleSettleDetect",
                                "DungeonBattleMatchLoop"
                            ]
                        },
                        "DungeonBattleTapAcceptOcr": {
                            "next": [
                                "DungeonBattleLoadingOcr",
                                "DungeonBattleCancelReadyOcr",
                                "DungeonBattleUiReadyOcr",
                                "DungeonBattleSettleDetect",
                                "DungeonBattleMatchLoop"
                            ]
                        }
                    }
                }
            ]
        },
        "check_hp": {
            "type": "select",
            "label": "$opt_check_hp",
            "description": "$opt_check_hp_desc",
            "default_case": "skip",
            "cases": [
                {
                    "name": "skip",
                    "label": "$opt_check_hp_skip",
                    "pipeline_override": {}
                },
                {
                    "name": "enable",
                    "label": "$opt_check_hp_enable",
                    "pipeline_override": {
                        "DungeonHpLowCheck": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "hp_threshold": {
            "type": "select",
            "label": "$opt_hp_threshold",
            "description": "$opt_hp_threshold_desc",
            "default_case": "t70",
            "cases": [
                {
                    "name": "t50",
                    "label": "$opt_hp_threshold_50",
                    "pipeline_override": {
                        "DungeonHpLowCheck": {
                            "count": 300
                        }
                    }
                },
                {
                    "name": "t70",
                    "label": "$opt_hp_threshold_70",
                    "pipeline_override": {
                        "DungeonHpLowCheck": {
                            "count": 180
                        }
                    }
                },
                {
                    "name": "t80",
                    "label": "$opt_hp_threshold_80",
                    "pipeline_override": {
                        "DungeonHpLowCheck": {
                            "count": 120
                        }
                    }
                },
                {
                    "name": "t90",
                    "label": "$opt_hp_threshold_90",
                    "pipeline_override": {
                        "DungeonHpLowCheck": {
                            "count": 60
                        }
                    }
                }
            ]
        },
        "claim_reward": {
            "type": "select",
            "label": "$opt_claim_reward",
            "description": "$opt_claim_reward_desc",
            "default_case": "claim",
            "cases": [
                {
                    "name": "claim",
                    "label": "$opt_claim_reward_claim",
                    "pipeline_override": {
                        "DungeonBattleClaimRewardOcr": {
                            "action": "Click",
                            "next": [
                                "DungeonBattleTapTopArea"
                            ]
                        }
                    }
                },
                {
                    "name": "skip",
                    "label": "$opt_claim_reward_skip",
                    "pipeline_override": {
                        "DungeonBattleClaimRewardOcr": {
                            "recognition": "DirectHit",
                            "action": "DoNothing",
                            "next": [
                                "DungeonBattleTapTopArea"
                            ],
                            "on_error": [
                                "DungeonBattleTapTopArea"
                            ]
                        }
                    }
                }
            ]
        }
    }
}