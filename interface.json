{
  "interface_version": 2,
  "languages": {
    "zh_cn": "interface_zh.json"
  },
  "name": "MaaZJCS",
  "label": "$project_name",
  "title": "$project_title",
  "version": "0.1.0",
  "description": "$project_description",
  "controller": [
    {
      "name": "Android",
      "label": "$controller_android",
      "description": "$controller_android_desc",
      "type": "Adb",
      "display_short_side": 720
    }
  ],
  "resource": [
    {
      "name": "Official",
      "label": "$resource_official",
      "description": "$resource_official_desc",
      "path": [
        "assets/resource"
      ],
      "controller": [
        "Android"
      ]
    }
  ],
  "task": [
    {
      "name": "StartupAndHome",
      "label": "$task_startup_home",
      "entry": "StartupEntry",
      "default_check": true,
      "description": "$task_startup_home_desc"
    },
    {
      "name": "DailyHandcart",
      "label": "$task_daily_handcart",
      "entry": "DailyHandcartEntry",
      "description": "$task_daily_handcart_desc"
    },
    {
      "name": "DailyHandcartFromCart",
      "label": "$task_daily_handcart_from_cart",
      "entry": "DailyHandcartAtCartEntry",
      "description": "$task_daily_handcart_from_cart_desc"
    },
    {
      "name": "DailyBed",
      "label": "$task_daily_bed",
      "entry": "DailyBedEntry",
      "description": "$task_daily_bed_desc"
    },
    {
      "name": "DailyShop",
      "label": "$task_daily_shop",
      "entry": "DailyShopEntry",
      "description": "$task_daily_shop_desc"
    },
    {
      "name": "DailyTasks",
      "label": "$task_daily_tasks",
      "entry": "DailyTasksEntry",
      "description": "$task_daily_tasks_desc"
    },
    {
      "name": "DailySignIn",
      "label": "$task_daily_sign_in",
      "entry": "DailySignInEntry",
      "description": "$task_daily_sign_in_desc"
    },
    {
      "name": "GrowthTrial",
      "label": "$task_growth_trial",
      "entry": "GrowthTrialEntry",
      "description": "$task_growth_trial_desc"
    },
    {
      "name": "DepartureSignIn",
      "label": "$task_departure_sign_in",
      "entry": "DepartureSignInEntry",
      "description": "$task_departure_sign_in_desc"
    },
    {
      "name": "MainQuest",
      "label": "$task_main_quest",
      "entry": "MainQuestEntry",
      "description": "$task_main_quest_desc"
    },
    {
      "name": "ExitGame",
      "label": "$task_exit_game",
      "entry": "ExitGameEntry",
      "description": "$task_exit_game_desc"
    }
  ]
}
